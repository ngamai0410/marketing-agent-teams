# Copy to .env and fill in your keys.
# Only the key matching your llm.provider in config.yaml is required.

ANTHROPIC_API_KEY=sk-ant-your-key-here
OPENAI_API_KEY=sk-your-key-here
GEMINI_API_KEY=your-gemini-key-here

# Only needed when search.provider=brave in config.yaml
BRAVE_API_KEY=your-brave-key-here

# ── Deploy (docker compose + Caddy) ──────────────────────────────
# SITE_ADDRESS: domain thật (vd dashboard.example.com) để Caddy bật HTTPS,
#   hoặc :80 khi test bằng IP. BASIC_AUTH_HASH: tạo bằng
#   docker run --rm caddy:2-alpine caddy hash-password -p 'YOUR_PASSWORD'
SITE_ADDRESS=:80
BASIC_AUTH_USER=admin
BASIC_AUTH_HASH=
